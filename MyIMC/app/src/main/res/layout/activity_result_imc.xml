<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activity_result_imc">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp"
        android:padding="15dp"
        >

        <TextView
            android:id="@+id/textView5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Résultat"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:layout_marginBottom="15dp"
            />

        <TextView
            android:id="@+id/res_imc_textView_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="36sp"
            android:textAlignment="center"
            android:layout_marginBottom="15dp"
            android:background="@color/dark_green"
            android:textColor="@color/white"
            android:textStyle="bold"
            />

        <TextView
            android:id="@+id/res_imc_textView_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="aucun résultat"
            android:layout_marginBottom="15dp"
            android:textSize="20sp"
            android:textAlignment="center"
            />

        <TextView
            android:id="@+id/res_imc_textView_cat0"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:text="    > 40 : Obésité sévère"
            android:textSize="16sp"
            android:background="@color/dark_red"
            android:textColor="@color/white"
            android:padding="8dp"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/res_imc_textView_cat1"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:text="40 - 35 : Obésité sévère"
            android:textSize="16sp"
            android:background="@color/light_red"
            android:textColor="@color/white"
            android:padding="8dp"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/res_imc_textView_cat2"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:text="35 - 30 : Obésité modérée"
            android:textSize="16sp"
            android:background="@color/brown"
            android:textColor="@color/white"
            android:padding="8dp"
            android:layout_gravity="center"
            />

        <TextView
            android:id="@+id/res_imc_textView_cat3"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:background="@color/light_green"
            android:padding="8dp"
            android:text="30 - 25 : Surpoids"
            android:textColor="@color/white"
            android:layout_gravity="center"
            android:textSize="16sp"
            />

        <TextView
            android:id="@+id/res_imc_textView_cat4"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@color/dark_green"
            android:padding="8dp"
            android:text="25 - 18,5 : Recommandé"
            android:textColor="@color/white"
            android:textSize="16sp"
            />

        <TextView
            android:id="@+id/res_imc_textView_cat5"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:text="18,5 - 16,5 : Maigreur"
            android:textSize="16sp"
            android:background="@color/turquoise"
            android:textColor="@color/white"
            android:padding="8dp"
            android:layout_gravity="center"
            />
        <TextView
            android:id="@+id/res_imc_textView_cat6"
            android:layout_width="275dp"
            android:layout_height="wrap_content"
            android:text="inférieur à 16,5 : Dénutrition"
            android:textSize="16sp"
            android:background="@color/blue"
            android:textColor="@color/white"
            android:padding="8dp"
            android:layout_gravity="center"
            android:layout_marginBottom="30dp"
            />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="italic"
            android:textSize="12sp"
            android:textAlignment="center"
            android:textColor="@color/light_gray"
            android:text="Avertissement : Ce calculateur est fourni à titre indicatif. Il ne convient pas aux enfants ni aux femmes enceintes. Pour toute question concernant votre santé, veuillez consulter un professionnel de santé." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="15dp"
            >

            <Button
                android:id="@+id/res_imc_button_recalculer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/light_gray"
                android:paddingHorizontal="15dp"
                android:paddingVertical="10dp"
                android:text="Refaire le calcul"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginRight="20dp"
                />

            <Button
                android:id="@+id/res_imc_button_historique"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/light_gray"
                android:paddingHorizontal="15dp"
                android:paddingVertical="10dp"
                android:text="Historique"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginLeft="20dp"
                />
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/resultat_imc_floatingActionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@android:drawable/ic_menu_revert"
        android:layout_margin="10dp"
        android:backgroundTint="@color/white"
        app:borderWidth="1dp"
        />
</androidx.constraintlayout.widget.ConstraintLayout>